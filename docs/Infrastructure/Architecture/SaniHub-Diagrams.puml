@startuml SaniHub-Event-Format
title SaniHub — Format Événement Standard

rectangle "Event Structure" {
    rectangle "Event Wrapper" {
        rectangle "message_id: UUID" 
        rectangle "correlation_id: string (e.g., CMD-12345)\n[links together all events for a business transaction]"
        rectangle "event_type: string (CommandeClientCree, OdfCreated, etc)"
        rectangle "timestamp: ISO8601"
        rectangle "source_app: string (dynamics365, M3, TrueCommerce, Ortems, BBX)"
        rectangle "target_apps: [string] (M3, Ortems)"
        rectangle "status: enum (Published | Routed | Delivered | Failed)"
        rectangle "retry_count: int"
        rectangle "created_by: ServiceAccount"
    }
    
    rectangle "Event Payload (Canonical)" {
        rectangle "data: {}\n[app-agnostic business data\n e.g., CommandeClient { id, dateCreation, client, lignes[], adresse_livraison }]"
        rectangle "metadata: {}\n[optional context: user_id, tenant_id, etc]"
        rectangle "transformations: []\n[audit trail of schema conversions]"
    }
}

rectangle "Event Routing Rules (Config)" {
    rectangle "Rule 1: IF event_type == CommandeClientCree THEN route to [M3, Ortems, Dynamics]"
    rectangle "Rule 2: IF event_type == OdfCreated THEN route to [Ortems, BBX] IF status != Draft"
    rectangle "Rule 3: IF event_type == ReceptionMarchandise THEN route to [Dynamics, M3] with retry(3, exponential)"
}

@enduml
