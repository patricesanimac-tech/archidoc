@startuml saniHub-C4-Containers
!include <C4/C4_Context>
!include <C4/C4_Container>

title SaniHub — C4 Model — Niveau 2 : Conteneurs

LAYOUT_TOP_DOWN()

Person(operator_it, "Opérateur IT", "Monitoring, troubleshooting")

System_Boundary(saniHub_system, "SaniHub System") {
    
    Container(api_gateway, "API Gateway", "Golang + Gin", "Point d'entrée REST/gRPC\n- Authentification OAuth 2.0\n- Rate limiting\n- Request/response logging")
    
    Container(router_orchestrator, "Router & Orchestrator", "Golang", "Cœur logique\n- Décide routage via rules\n- Saga orchestration\n- Correlation ID tracking")
    
    Container(transformer, "Event Transformer & Validator", "Golang + JSON Schema", "Conversion d'événements\n- Canonical ↔ Format app\n- Validation schémas\n- Error formulation")
    
    Container(connector_manager, "Connector Manager & Registry", "Golang", "Gère tous les connecteurs\n- Factory pattern pour créer adapters\n- Health checks\n- Retry logic")
    
    Container(message_broker, "Message Broker (RabbitMQ/Kafka)", "RabbitMQ 3.11 | Kafka 3.5", "Découplage async\n- Topics: events, commands, errors\n- Persistent queues\n- Fanout par type événement")
    
    Container(event_store, "Event Store (PostgreSQL)", "PostgreSQL 15", "Log immuable\n- Append-only table: events\n- JSONB payload\n- Indexed by correlation_id, timestamp, source_app")
    
    Container(state_store, "State Store & Deduplication", "Redis 7", "Cache état transitoire\n- En-cours transactions\n- Message dedup keys (15 min TTL)\n- Connector health status")
    
    Container(observability_stack, "Observability Stack", "Prometheus\n+ Grafana\n+ ELK\n+ Jaeger", "Monitoring & Tracing\n- Prometheus metrics\n- Grafana dashboards\n- Elasticsearch logs\n- Jaeger traces")
    
    Container(dashboard_control, "Dashboard & Control Plane", "React + Node.js", "Web UI\n- Real-time status\n- Replay manual\n- Routage rules config\n- Alerts")
}

System_Ext(apps, "Applications Métier\n(M3, Dynamics, Ortems, BBX, TrueCommerce)", "Systems externes")

Rel(apps, api_gateway, "1. Publient événements", "REST POST\n/api/v1/events/publish")
Rel(api_gateway, router_orchestrator, "2a. Route decision", "gRPC")
Rel(router_orchestrator, transformer, "2b. Transform canonique", "gRPC")
Rel(transformer, message_broker, "3. Publie canonical event", "AMQP / Kafka API")
Rel(message_broker, message_broker, "4. Fanout subscribers", "Route dépend type événement")
Rel(message_broker, connector_manager, "5. Connecteur reçoit", "Consume topic")
Rel(connector_manager, apps, "6. Écrit app cible", "OData / REST / JDBC / API maison")

Rel(message_broker, event_store, "LOG: Persist event", "SQL INSERT (async)")
Rel(connector_manager, state_store, "STATUS: Update", "Redis SET")
Rel(router_orchestrator, state_store, "TRACK: Dedup, saga state", "Redis GET/SET")

Rel(api_gateway, observability_stack, "Telemetry", "Metrics, logs, traces")
Rel(router_orchestrator, observability_stack, "Telemetry", "Metrics, logs, traces")
Rel(connector_manager, observability_stack, "Telemetry", "Metrics, logs, traces")

Rel(event_store, observability_stack, "Expose metrics", "Ready-only")
Rel(state_store, observability_stack, "Expose health", "Ready-only")

Rel(observability_stack, dashboard_control, "Push data", "HTTP/WebSocket")
Rel(operator_it, dashboard_control, "Monitor & Control", "Browser (Vue Web)")

Rel(dashboard_control, api_gateway, "Admin APIs\n/replay, /config", "REST/gRPC")

SHOW_LEGEND()

@enduml

